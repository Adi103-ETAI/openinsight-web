# OpenInsight — Environment Variables
# Copy this file to .env.local and fill in real values.
# Also set the same NEXT_PUBLIC_* vars in Vercel → Project → Settings → Environment Variables.

# ─── Supabase ─────────────────────────────────────────────
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...   # public, safe for browser (RLS protects data)
SUPABASE_SERVICE_ROLE_KEY=eyJ...       # SERVER ONLY — never expose in browser

# ─── Resend (transactional email) ─────────────────────────
# resend.com → API Keys
RESEND_API_KEY=re_...
# System/brand address — for admin notifications (internal)
RESEND_FROM_EMAIL=OpenInsight <hello@openinsight.in>
# Founder address — for user-facing emails (welcome, contact auto-reply)
# This is what doctors see in their inbox — builds personal trust.
RESEND_FOUNDER_EMAIL=Adii <adii@openinsight.in>
# Where signup & contact notification emails get sent (your inbox)
ADMIN_NOTIFY_EMAIL=you@example.com

# ─── Admin access ─────────────────────────────────────────
# Comma-separated list of emails allowed to view /admin dashboard
ADMIN_EMAILS=you@example.com,cofounder@example.com

# ─── PostHog (product analytics) ──────────────────────────
# posthog.com → Project Settings → API Key
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── Microsoft Clarity (session recordings) ───────────────
# clarity.microsoft.com → project ID
NEXT_PUBLIC_CLARITY_PROJECT_ID=xxxxxxxx
